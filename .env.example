# Public origin. Production checkout refuses localhost and requires this value.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase service role (server-only). P6 provisions the project and applies sql/.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe TEST mode only. The app rejects keys that do not begin with sk_test_.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PRICE_QUICK=price_test_quick_placeholder
STRIPE_PRICE_FULL=price_test_full_placeholder
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder

# Optional Resend notification after contact persistence.
# Leave blank in local/test; the row remains email_status=pending.
RESEND_API_KEY=
CONTACT_EMAIL_TO=support@novique.ai
CONTACT_EMAIL_FROM=AI Act Ready <onboarding@resend.dev>
